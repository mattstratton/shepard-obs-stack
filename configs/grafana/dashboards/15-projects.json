{
  "uid": "shepherd-projects",
  "id": null,
  "title": "Shepherd / 10 Projects & Skills",
  "description": "Per-repo cost and token attribution, skill/slash-command usage, subagent launches, and MCP calls. Claude Code only.",
  "editable": true,
  "refresh": "1m",
  "weekStart": "monday",
  "panels": [
    {
      "id": 100,
      "title": "Projects",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 1,
      "title": "Cost by Repo",
      "description": "Computed from configs/pricing/model-prices.json rates. Claude Code only.",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (git_repo) (increase(shepherd:claude:computed_cost_usd{git_repo=~\"$git_repo\"}[$__range]))",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ],
        "cellHeight": "sm"
      }
    },
    {
      "id": 2,
      "title": "Cost Over Time by Repo",
      "description": "Claude Code only. Computed from configs/pricing/model-prices.json rates.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (git_repo) (increase(shepherd:claude:computed_cost_usd{git_repo=~\"$git_repo\"}[5m]))",
          "legendFormat": "{{git_repo}}",
          "queryType": "range",
          "refId": "A",
          "interval": "1m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 0,
            "showPoints": "never"
          },
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      }
    },
